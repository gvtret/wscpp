# Doxyfile for wscpp API documentation

PROJECT_NAME           = wscpp
PROJECT_BRIEF          = "Lightweight WebSocket stack for C++11"
PROJECT_NUMBER         = @WSCPP_VERSION@
OUTPUT_DIRECTORY       = @CMAKE_BINARY_DIR@/docs
CREATE_SUBDIRS         = NO

INPUT                  = @CMAKE_SOURCE_DIR@/include/wscpp
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp
EXCLUDE                = @CMAKE_SOURCE_DIR@/include/wscpp/detail

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES

MARKDOWN_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
AUTOLINK_SUPPORT       = YES

USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/docs/README.md
